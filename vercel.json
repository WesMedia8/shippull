{
  "version": 2,
  "builds": [
    {"src": "api/**/*.py", "use": "@vercel/python"},
    {"src": "public/**", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/api/auth", "dest": "/api/auth.py"},
    {"src": "/api/callback", "dest": "/api/callback.py"},
    {"src": "/api/sync", "dest": "/api/sync.py"},
    {"src": "/(.*)", "dest": "/public/$1"}
  ]
}
